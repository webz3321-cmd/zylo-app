{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury masterpiece product in the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "rating": { "type": "number" },
        "ratingCount": { "type": "number" },
        "isNew": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "isTrending": { "type": "boolean" },
        "isBestSeller": { "type": "boolean" },
        "variants": { "type": "array" },
        "features": { "type": "array" },
        "specs": { "type": "object" }
      },
      "required": ["name", "price", "category", "images"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category salon.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "deliveryStatus": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "A customer or admin profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "phone": { "type": "string" },
        "addresses": { "type": "array" },
        "createdAt": { "type": "string" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "A product review from a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "title": { "type": "string" },
        "comment": { "type": "string" },
        "date": { "type": "string" },
        "verified": { "type": "boolean" },
        "likes": { "type": "number" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount coupon.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "value": { "type": "number" },
        "minSpend": { "type": "number" },
        "expiryDate": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Offer": {
      "title": "Offer",
      "description": "A marketing offer or banner.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "HeroSlide": {
      "title": "HeroSlide",
      "description": "A slide for the homepage hero slider.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "badge": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "buttonText": { "type": "string" },
        "link": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "AuthorizedAdmin": {
      "title": "AuthorizedAdmin",
      "description": "An email address authorized for admin access.",
      "type": "object",
      "properties": {
        "authorizedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of luxury products."
    },
    "/rich_categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of product reviews."
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Collection of discount coupons."
    },
    "/offers/{offerId}": {
      "schema": "Offer",
      "description": "Collection of marketing offers."
    },
    "/hero/{slideId}": {
      "schema": "HeroSlide",
      "description": "Collection of hero slider slides."
    },
    "/authorized_admins/{email}": {
      "schema": "AuthorizedAdmin",
      "description": "Collection of authorized admin emails."
    }
  }
}
